{
  "$schema": "https://raw.githubusercontent.com/oxc-project/oxc/main/crates/oxc_linter/src/rules.rs",
  "rules": {
    "no-unused-vars": "warn",
    "no-console": "warn",
    "eqeqeq": "error",
    "no-var": "error",
    "prefer-const": "error"
  },
  "ignorePatterns": [
    "node_modules",
    "dist",
    ".nuxt",
    ".output",
    "*.min.js",
    "apps/frontend/src/types/api.ts"
  ]
}
