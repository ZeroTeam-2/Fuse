# Shell-скрипты, которые монтируются в контейнеры, ОБЯЗАНЫ иметь LF.
# С CRLF шебанг читается как интерпретатор "/bin/bash\r", и запуск падает с
# невразумительным "No such file or directory" (речь про интерпретатор, а не
# про сам скрипт). На Windows с core.autocrlf=true это происходит молча при
# каждом checkout — так у нас годами не создавалась SQS-очередь в LocalStack.
*.sh text eol=lf
