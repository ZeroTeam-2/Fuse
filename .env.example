# Базовый профиль окружения.
#
# Для разработки против локальной инфраструктуры в докере НЕ нужно править этот
# файл: `pnpm infra` + `cp .env.local.example .env.local`. Файл .env.local
# перекрывает .env по заданным в нём переменным (MONGODB_URL, AWS_*, S3_*), а
# всё остальное — JWT, OAuth — берётся отсюда. Удалить .env.local = вернуться к
# сервисам, прописанным здесь.

# ─── Backend (apps/backend) ───────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
# MongoDB. Локальный контейнер (docker-compose.dev.yml) слушает 27018 на хосте —
# порт нестандартный, чтобы не конфликтовать с системным mongod на 27017.
MONGODB_URL=mongodb://fuse:fusepassword@localhost:27018/fuse?authSource=admin

# SQS-совместимая очередь исполнения сценариев.
# Коду нужен ТОЛЬКО Queue URL (+ регион и креды). ARN из консоли провайдера
# приложением не используется — очередь/DLQ создаются на стороне провайдера.
#
# Ниже — активный профиль (LocalStack для локальной разработки).
# Для prod раскомментируй нужный блок и закомментируй LocalStack.

# ─ Профиль 1: LocalStack (локальная разработка, дефолт) ─
AWS_REGION=us-east-1
AWS_SQS_QUEUE_URL=http://localhost:4566/000000000000/scenario-execution
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_ENDPOINT_URL=http://localhost:4566

# ─ Профиль 3: Yandex Cloud Message Queue (SQS-совместимая) ─
# Регион всегда ru-central1; AWS_ENDPOINT_URL здесь ОБЯЗАТЕЛЕН.
# Ключи создаются как "статический ключ доступа" сервисного аккаунта
# (IAM → Сервисные аккаунты → создать статический ключ), а НЕ в обзоре очереди.
# AWS_REGION=ru-central1
# AWS_ENDPOINT_URL=https://message-queue.api.cloud.yandex.net
# AWS_SQS_QUEUE_URL=https://message-queue.api.cloud.yandex.net/b1g<...>/scenario-execution
# AWS_ACCESS_KEY_ID=<идентификатор статического ключа>
# AWS_SECRET_ACCESS_KEY=<секретный ключ>

# MinIO (S3-совместимое файловое хранилище)
# S3_URL — хост или полный URL. Со схемой https порт и TLS берутся из неё:
#   S3_URL=https://s3.twcstorage.ru  (внешний S3, S3_PORT оставить пустым)
# S3_PORT нужен только для нестандартного порта, как у локального minio.
S3_URL=localhost
S3_PORT=9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=fuse

# JWT (сессии пользователей)
JWT_SECRET=change-me-to-a-random-string-of-at-least-32-characters
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Yandex OAuth
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
YANDEX_REDIRECT_URI=http://localhost:3001/api/auth/callback
# URL фронтенда: куда редиректить пользователя после OAuth-callback,
# и origin для CORS в dev-режиме (cross-origin 5173 -> 3001).
APP_URL=http://localhost:5173

# ─── Лимиты размера файлов ────────────────────────────────────────────────────
# Единый источник дефолтов — apps/backend/src/config/file-limits.constants.ts.
# Порог single vs chunked upload (MB)
FILE_SINGLE_UPLOAD_MAX_MB=10
# Лимит загрузки файла OpenAPI-спеки (MB). Ограничен так, чтобы импорт влезал в
# документ MongoDB (потолок 16 MB).
SPEC_FILE_MAX_MB=15
# Лимит размера ответа при загрузке спеки по URL, SSRF-guard (MB)
SPEC_URL_FETCH_MAX_MB=10


# Структурированное логирование
LOG_COLLECTOR_URL=
MONIUM_ENABLED=

# ─── Frontend (apps/frontend) ─────────────────────────────────────────────────
# Публичные переменные (доступны на клиенте) — префикс NUXT_PUBLIC_
# Используется только при локальной разработке. В docker compose фронтенд
# работает за caddy и значение жёстко задано как "/" (same-origin, /api/*
# проксируется в backend).
NUXT_PUBLIC_API_BASE_URL=http://localhost:3001

# Yandex Metrica (пусто = отключено)
NUXT_PUBLIC_YANDEX_METRIKA_ID=

# Порог single vs chunked upload для фронтенда (MB)
FILE_SINGLE_UPLOAD_MAX_MB=10
# Лимит загрузки файла спеки для клиентской валидации в дропзоне (MB)
SPEC_FILE_MAX_MB=15

# ─── Caddy (docker-compose) ───────────────────────────────────────────────────
# Порт, на котором caddy принимает трафик: http://localhost:${HTTP_PORT}
HTTP_PORT=8081

# Серверные переменные (только SSR) — префикс NUXT_
NUXT_SESSION_SECRET=change-me-to-a-random-string-of-at-least-32-characters
