{
  "name": "@fuse/shared",
  "version": "0.0.1",
  "description": "Shared types and interfaces for Fuse monorepo",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
