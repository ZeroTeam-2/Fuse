# Локальный профиль: бэкенд на хосте → инфраструктура в докере.
#
#   pnpm infra                        # поднять mongo / sqs / minio
#   cp .env.local.example .env.local  # включить этот профиль
#   pnpm dev                          # фронт и бэк на хосте
#
# Этот файл перекрывает .env по каждой заданной здесь переменной; всё остальное
# (JWT_SECRET, OAuth-креды, ...) продолжает браться из .env. Чтобы вернуться к
# удалённым сервисам — удалите .env.local. Сам .env при этом не меняется.
#
# .env.local в .gitignore. Секретов здесь нет и быть не должно: все креды ниже —
# это дефолты локальных контейнеров.

# MongoDB (docker-compose.dev.yml, порт 27018 — чтобы не конфликтовать с
# системным mongod на 27017).
MONGODB_URL=mongodb://fuse:fusepassword@localhost:27018/fuse?authSource=admin

# SQS через LocalStack. Очередь scenario-execution (+ DLQ) создаётся автоматически
# при старте контейнера, см. docker/localstack/init-sqs.sh.
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=http://localhost:4566
AWS_SQS_QUEUE_URL=http://localhost:4566/000000000000/scenario-execution
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# MinIO. S3_PORT обязателен: порт нестандартный, из схемы http:// его не вывести.
# Бакет создаётся автоматически (docker/minio/init-bucket.sh).
S3_URL=localhost
S3_PORT=9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=fuse
