# Reverse proxy: /api/* -> backend (NestJS), остальное -> frontend (Nuxt).
# Backend использует глобальный префикс "api", поэтому путь не переписывается.
:8081 {
	handle /api/* {
		reverse_proxy backend:3001
	}

	# socket.io живёт вне глобального префикса "api" — у него свой путь
	# /socket.io/ (namespace "runs" передаётся внутри протокола, не в URL).
	# Upgrade до websocket caddy проксирует сам.
	handle /socket.io/* {
		reverse_proxy backend:3001
	}

	handle {
		reverse_proxy frontend:5173
	}
}
