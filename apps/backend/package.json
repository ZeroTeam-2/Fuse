{
  "name": "@fuse/backend",
  "version": "0.0.1",
  "description": "Fuse backend — NestJS + MongoDB",
  "scripts": {
    "prebuild": "pnpm --filter @fuse/shared build",
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:infra": "vitest run --config vitest.infra.config.ts",
    "backfill:base-url": "node scripts/backfill-app-base-url.mts",
    "seed": "node scripts/seed-local.mts"
  },
  "dependencies": {
    "@fuse/shared": "workspace:*",
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mongoose": "^11.0.4",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/platform-socket.io": "^11.1.28",
    "@nestjs/serve-static": "^5.0.5",
    "@nestjs/swagger": "^11.4.5",
    "@nestjs/websockets": "^11.1.28",
    "@readme/openapi-parser": "^6.2.1",
    "@scalar/nestjs-api-reference": "^1.2.8",
    "@aws-sdk/client-sqs": "^3.731.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "cookie-parser": "^1.4.7",
    "minio": "^8.0.7",
    "mongoose": "^8.15.0",
    "multer": "^2.2.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.3",
    "sqs-consumer": "^11.5.1",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.7",
    "@nestjs/testing": "^11.1.27",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.3",
    "@types/multer": "^2.2.0",
    "@types/node": "^24.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^7.2.0",
    "openapi-types": "^12.1.3",
    "supertest": "^7.2.2",
    "typescript": "^5.8.3",
    "vitest": "^4.1.10"
  }
}
